{
  "$id": "archistrator://contract/construction",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$defs": {
    "ActivityID": {
      "type": "string"
    },
    "ActivityOverride": {
      "type": "object",
      "properties": {
        "kind": {
          "$ref": "#/$defs/OverrideKind"
        },
        "notes": {
          "type": "string"
        }
      },
      "required": [
        "kind",
        "notes"
      ],
      "additionalProperties": false
    },
    "ConstructionSessionView": {
      "type": "object",
      "properties": {
        "projectId": {
          "$ref": "#/$defs/ProjectID",
          "x-go-name": "ProjectID"
        },
        "activityId": {
          "type": [
            "null"
          ],
          "$ref": "#/$defs/ActivityID",
          "x-go-name": "ActivityID"
        },
        "stage": {
          "$ref": "#/$defs/ConstructionStage"
        },
        "pipelinePhase": {
          "type": [
            "null"
          ],
          "$ref": "#/$defs/PipelinePhase"
        },
        "reviewSet": {
          "type": [
            "null"
          ],
          "$ref": "#/$defs/ReviewSet"
        },
        "variance": {
          "type": [
            "null"
          ],
          "$ref": "#/$defs/FlaggedVariance"
        }
      },
      "required": [
        "projectId",
        "stage"
      ],
      "additionalProperties": false
    },
    "ConstructionStage": {
      "type": "integer",
      "enum": [
        0,
        1,
        2,
        3,
        4,
        5,
        6
      ],
      "x-enum-varnames": [
        "ConstructionStageUnknown",
        "StageDispatching",
        "StagePipelineRunning",
        "StageReviewing",
        "StageAwaitingTakeover",
        "StagePaused",
        "StageExited"
      ],
      "x-go-base": "int"
    },
    "FlaggedVariance": {
      "type": "object",
      "properties": {
        "projectId": {
          "$ref": "#/$defs/ProjectID",
          "x-go-name": "ProjectID"
        },
        "activityId": {
          "$ref": "#/$defs/ActivityID",
          "x-go-name": "ActivityID"
        },
        "summary": {
          "type": "string"
        }
      },
      "required": [
        "projectId",
        "activityId",
        "summary"
      ],
      "additionalProperties": false
    },
    "OverrideKind": {
      "type": "integer",
      "enum": [
        0,
        1,
        2,
        3,
        4
      ],
      "x-enum-varnames": [
        "OverrideUnknown",
        "OverrideTakeover",
        "OverrideRetry",
        "OverrideSkip",
        "OverrideReassign"
      ],
      "x-go-base": "int"
    },
    "PipelinePhase": {
      "type": "integer",
      "enum": [
        0,
        1,
        2,
        3,
        4,
        5
      ],
      "x-enum-varnames": [
        "PipelinePhaseUnknown",
        "PipelinePending",
        "PipelineRunning",
        "PipelineSucceeded",
        "PipelineFailed",
        "PipelineCancelled"
      ],
      "x-go-base": "int"
    },
    "ProjectID": {
      "type": "string"
    },
    "PumpResult": {
      "type": "object",
      "properties": {
        "dispatched": {
          "type": "boolean"
        },
        "activityId": {
          "type": [
            "null"
          ],
          "$ref": "#/$defs/ActivityID",
          "x-go-name": "ActivityID"
        }
      },
      "required": [
        "dispatched"
      ],
      "additionalProperties": false
    },
    "ReplanSweepResult": {
      "type": "object",
      "properties": {
        "flaggedVariances": {
          "type": [
            "null",
            "array"
          ],
          "items": {
            "$ref": "#/$defs/FlaggedVariance"
          }
        }
      },
      "additionalProperties": false
    },
    "ReviewSet": {
      "type": "object",
      "properties": {
        "reviewers": {
          "type": [
            "null",
            "array"
          ],
          "items": {
            "$ref": "#/$defs/Reviewer"
          }
        }
      },
      "additionalProperties": false
    },
    "Reviewer": {
      "type": "object",
      "properties": {
        "role": {
          "type": "string"
        },
        "perspective": {
          "type": "string"
        },
        "referenceArtifact": {
          "type": [
            "null",
            "string"
          ]
        },
        "mayAmend": {
          "type": "boolean"
        }
      },
      "required": [
        "role",
        "perspective",
        "mayAmend"
      ],
      "additionalProperties": false
    }
  },
  "title": "construction contract",
  "interface": {
    "name": "ConstructionManager",
    "layer": "manager",
    "operations": [
      {
        "name": "ExecuteNextActivity",
        "params": [
          {
            "name": "projectID",
            "schema": {
              "$ref": "#/$defs/ProjectID"
            }
          },
          {
            "name": "tickID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "result": {
          "$ref": "#/$defs/PumpResult"
        },
        "error": true
      },
      {
        "name": "GetSessionState",
        "params": [
          {
            "name": "projectID",
            "schema": {
              "$ref": "#/$defs/ProjectID"
            }
          },
          {
            "name": "activityID",
            "pointer": true,
            "schema": {
              "$ref": "#/$defs/ActivityID"
            }
          }
        ],
        "result": {
          "$ref": "#/$defs/ConstructionSessionView"
        },
        "error": true
      },
      {
        "name": "OverrideActivity",
        "params": [
          {
            "name": "projectID",
            "schema": {
              "$ref": "#/$defs/ProjectID"
            }
          },
          {
            "name": "activityID",
            "schema": {
              "$ref": "#/$defs/ActivityID"
            }
          },
          {
            "name": "override",
            "schema": {
              "$ref": "#/$defs/ActivityOverride"
            }
          }
        ],
        "error": true
      },
      {
        "name": "PauseProject",
        "params": [
          {
            "name": "projectID",
            "schema": {
              "$ref": "#/$defs/ProjectID"
            }
          },
          {
            "name": "reason",
            "schema": {
              "type": "string"
            }
          }
        ],
        "error": true
      },
      {
        "name": "RunReplanSweep",
        "params": [
          {
            "name": "projectID",
            "pointer": true,
            "schema": {
              "$ref": "#/$defs/ProjectID"
            }
          },
          {
            "name": "tickID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "result": {
          "$ref": "#/$defs/ReplanSweepResult"
        },
        "error": true
      }
    ]
  }
}
