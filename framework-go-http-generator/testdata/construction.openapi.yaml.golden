components:
  schemas:
    ActivityID:
      type: string
    ActivityOverride:
      additionalProperties: false
      properties:
        kind:
          $ref: '#/components/schemas/OverrideKind'
        notes:
          type: string
      required:
        - kind
        - notes
      type: object
    ConstructionSessionView:
      additionalProperties: false
      properties:
        activityId:
          $ref: '#/components/schemas/ActivityID'
          type:
            - "null"
          x-go-name: ActivityID
        pipelinePhase:
          $ref: '#/components/schemas/PipelinePhase'
          type:
            - "null"
        projectId:
          $ref: '#/components/schemas/ProjectID'
          x-go-name: ProjectID
        reviewSet:
          $ref: '#/components/schemas/ReviewSet'
          type:
            - "null"
        stage:
          $ref: '#/components/schemas/ConstructionStage'
        variance:
          $ref: '#/components/schemas/FlaggedVariance'
          type:
            - "null"
      required:
        - projectId
        - stage
      type: object
    ConstructionStage:
      enum:
        - 0
        - 1
        - 2
        - 3
        - 4
        - 5
        - 6
      type: integer
      x-enum-varnames:
        - ConstructionStageUnknown
        - StageDispatching
        - StagePipelineRunning
        - StageReviewing
        - StageAwaitingTakeover
        - StagePaused
        - StageExited
      x-go-base: int
    ErrorResponse:
      additionalProperties: false
      properties:
        code:
          type: string
        error:
          type: string
      required:
        - error
        - code
      type: object
    FlaggedVariance:
      additionalProperties: false
      properties:
        activityId:
          $ref: '#/components/schemas/ActivityID'
          x-go-name: ActivityID
        projectId:
          $ref: '#/components/schemas/ProjectID'
          x-go-name: ProjectID
        summary:
          type: string
      required:
        - projectId
        - activityId
        - summary
      type: object
    OverrideKind:
      enum:
        - 0
        - 1
        - 2
        - 3
        - 4
      type: integer
      x-enum-varnames:
        - OverrideUnknown
        - OverrideTakeover
        - OverrideRetry
        - OverrideSkip
        - OverrideReassign
      x-go-base: int
    PipelinePhase:
      enum:
        - 0
        - 1
        - 2
        - 3
        - 4
        - 5
      type: integer
      x-enum-varnames:
        - PipelinePhaseUnknown
        - PipelinePending
        - PipelineRunning
        - PipelineSucceeded
        - PipelineFailed
        - PipelineCancelled
      x-go-base: int
    ProjectID:
      type: string
    PumpResult:
      additionalProperties: false
      properties:
        activityId:
          $ref: '#/components/schemas/ActivityID'
          type:
            - "null"
          x-go-name: ActivityID
        dispatched:
          type: boolean
      required:
        - dispatched
      type: object
    ReplanSweepResult:
      additionalProperties: false
      properties:
        flaggedVariances:
          items:
            $ref: '#/components/schemas/FlaggedVariance'
          type:
            - "null"
            - array
      type: object
    ReviewSet:
      additionalProperties: false
      properties:
        reviewers:
          items:
            $ref: '#/components/schemas/Reviewer'
          type:
            - "null"
            - array
      type: object
    Reviewer:
      additionalProperties: false
      properties:
        mayAmend:
          type: boolean
        perspective:
          type: string
        referenceArtifact:
          type:
            - "null"
            - string
        role:
          type: string
      required:
        - role
        - perspective
        - mayAmend
      type: object
  securitySchemes:
    bearerAuth:
      scheme: bearer
      type: http
info:
  title: Construction API
  version: 1.0.0
openapi: 3.1.0
paths:
  /api/v1/construction/execute-next-activity/{projectID}:
    post:
      operationId: ExecuteNextActivity
      parameters:
        - in: path
          name: projectID
          required: true
          schema:
            $ref: '#/components/schemas/ProjectID'
      requestBody:
        content:
          application/json:
            schema:
              properties:
                tickID:
                  type: string
              required:
                - tickID
              type: object
        required: true
      responses:
        "200":
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/PumpResult'
          description: success
        "400":
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
          description: contract misuse
        "401":
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
          description: unauthenticated
        "403":
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
          description: forbidden
        "404":
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
          description: not found
        "409":
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
          description: failed precondition
        "500":
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
          description: internal error
        "503":
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
          description: infrastructure unavailable
      security:
        - bearerAuth: []
  /api/v1/construction/get-session-state/{projectID}/{activityID}:
    get:
      operationId: GetSessionState
      parameters:
        - in: path
          name: projectID
          required: true
          schema:
            $ref: '#/components/schemas/ProjectID'
        - in: path
          name: activityID
          required: true
          schema:
            $ref: '#/components/schemas/ActivityID'
      responses:
        "200":
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ConstructionSessionView'
          description: success
        "400":
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
          description: contract misuse
        "401":
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
          description: unauthenticated
        "403":
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
          description: forbidden
        "404":
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
          description: not found
        "409":
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
          description: failed precondition
        "500":
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
          description: internal error
        "503":
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
          description: infrastructure unavailable
      security:
        - bearerAuth: []
  /api/v1/construction/override-activity/{projectID}/{activityID}:
    post:
      operationId: OverrideActivity
      parameters:
        - in: path
          name: projectID
          required: true
          schema:
            $ref: '#/components/schemas/ProjectID'
        - in: path
          name: activityID
          required: true
          schema:
            $ref: '#/components/schemas/ActivityID'
      requestBody:
        content:
          application/json:
            schema:
              properties:
                override:
                  $ref: '#/components/schemas/ActivityOverride'
              required:
                - override
              type: object
        required: true
      responses:
        "204":
          description: no content
        "400":
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
          description: contract misuse
        "401":
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
          description: unauthenticated
        "403":
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
          description: forbidden
        "404":
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
          description: not found
        "409":
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
          description: failed precondition
        "500":
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
          description: internal error
        "503":
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
          description: infrastructure unavailable
      security:
        - bearerAuth: []
  /api/v1/construction/pause-project/{projectID}:
    post:
      operationId: PauseProject
      parameters:
        - in: path
          name: projectID
          required: true
          schema:
            $ref: '#/components/schemas/ProjectID'
      requestBody:
        content:
          application/json:
            schema:
              properties:
                reason:
                  type: string
              required:
                - reason
              type: object
        required: true
      responses:
        "204":
          description: no content
        "400":
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
          description: contract misuse
        "401":
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
          description: unauthenticated
        "403":
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
          description: forbidden
        "404":
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
          description: not found
        "409":
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
          description: failed precondition
        "500":
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
          description: internal error
        "503":
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
          description: infrastructure unavailable
      security:
        - bearerAuth: []
  /api/v1/construction/run-replan-sweep/{projectID}:
    post:
      operationId: RunReplanSweep
      parameters:
        - in: path
          name: projectID
          required: true
          schema:
            $ref: '#/components/schemas/ProjectID'
      requestBody:
        content:
          application/json:
            schema:
              properties:
                tickID:
                  type: string
              required:
                - tickID
              type: object
        required: true
      responses:
        "200":
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ReplanSweepResult'
          description: success
        "400":
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
          description: contract misuse
        "401":
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
          description: unauthenticated
        "403":
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
          description: forbidden
        "404":
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
          description: not found
        "409":
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
          description: failed precondition
        "500":
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
          description: internal error
        "503":
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
          description: infrastructure unavailable
      security:
        - bearerAuth: []
security:
  - bearerAuth: []
