        "AutoscaleNoChange",
        "AutoscaleScaleUp",
        "AutoscaleScaleDown",
        "AutoscalePause",
        "AutoscaleResume"
      ],
      "x-go-base": "int"
    },
    "AutoscaleDecisionView": {
      "type": "object",
      "properties": {
        "At": {
          "type": "string",
          "format": "date-time",
          "x-go-import": "time",
          "x-go-type": "time.Time"
        },
        "Action": {
          "$ref": "#/$defs/AutoscaleAction"
        },
        "Reason": {
          "type": "string"
        },
        "Published": {
          "type": "boolean"
        }
      },
      "required": [
        "At",
        "Action",
        "Reason",
        "Published"
      ],
      "additionalProperties": false
    },
    "AutoscalerMode": {
      "type": "integer",
      "enum": [
        0,
        1,
        2
      ],
      "x-enum-varnames": [
        "AutoscalerModeUnknown",
        "AutoscalerModeAuto",
        "AutoscalerModeManual"
      ],
      "x-go-base": "int"
    },
