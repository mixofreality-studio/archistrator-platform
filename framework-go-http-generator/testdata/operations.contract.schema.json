          {
            "name": "scope",
            "pointer": true,
            "schema": {
              "$ref": "#/$defs/ReconcileScope"
            }
          }
        ],
        "result": {
          "$ref": "#/$defs/ReconcileResult"
        },
        "error": true
      },
      {
        "name": "WithdrawSystem",
        "params": [
          {
            "name": "operatedAppID",
            "schema": {
              "type": "string",
              "format": "uuid",
              "x-go-import": "github.com/google/uuid",
              "x-go-type": "uuid.UUID"
            }
          },
          {
            "name": "changeID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "reason",
            "schema": {
              "$ref": "#/$defs/WithdrawReason"
            }
          }
        ],
        "result": {
          "$ref": "#/$defs/WithdrawResult"
        },
        "error": true
      }
