        },
        "ScaleWhatIfCurve": {
          "$ref": "#/$defs/WhatIfCurve"
        }
      },
      "required": [
        "CurrentRunRate",
        "ProjectedMonthlyCost",
        "ScaleWhatIfCurve"
      ],
      "additionalProperties": false
    },
