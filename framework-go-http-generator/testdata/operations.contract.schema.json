  "title": "operations contract",
  "interface": {
    "name": "OperationsManager",
    "layer": "manager",
    "operations": [
      {
        "name": "ApplyDelinquencyPolicy",
        "params": [
          {
            "name": "customerID",
            "schema": {
              "type": "string",
              "format": "uuid",
              "x-go-import": "github.com/google/uuid",
              "x-go-type": "uuid.UUID"
            }
          },
          {
            "name": "delinquencyContext",
            "schema": {
              "$ref": "#/$defs/DelinquencyContext"
            }
          }
        ],
        "error": true
      },
      {
        "name": "DeployAfterConstruction",
        "params": [
          {
            "name": "operatedAppID",
            "schema": {
              "type": "string",
              "format": "uuid",
              "x-go-import": "github.com/google/uuid",
              "x-go-type": "uuid.UUID"
            }
          },
          {
            "name": "change",
            "schema": {
              "$ref": "#/$defs/DesiredStateChange"
            }
          }
        ],
        "result": {
          "$ref": "#/$defs/DeployResult"
        },
        "error": true
      },
      {
        "name": "QueryCostProjection",
        "params": [
          {
            "name": "operatedAppID",
            "schema": {
              "type": "string",
              "format": "uuid",
              "x-go-import": "github.com/google/uuid",
              "x-go-type": "uuid.UUID"
            }
          },
          {
            "name": "requestID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "points",
            "pointer": true,
            "schema": {
              "$ref": "#/$defs/ScaleWhatIfPoints"
            }
          }
        ],
        "result": {
          "$ref": "#/$defs/CostProjectionSeam"
        },
        "error": true
      },
      {
        "name": "QueryOperatedSystemView",
        "params": [
          {
            "name": "operatedAppID",
            "schema": {
              "type": "string",
              "format": "uuid",
              "x-go-import": "github.com/google/uuid",
              "x-go-type": "uuid.UUID"
            }
          },
          {
            "name": "requestID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "result": {
          "$ref": "#/$defs/OperatedSystemView"
        },
        "error": true
      },
      {
        "name": "ReconcileOperatedState",
        "params": [
          {
            "name": "tickID",
