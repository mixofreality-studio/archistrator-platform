          "type": "boolean"
        },
        "Healthy": {
          "type": "boolean"
        }
      },
      "required": [
        "Component",
        "Objective",
        "SloMet",
        "Healthy"
      ],
      "additionalProperties": false
    },
    "WhatIfCurve": {
      "type": "object",
      "properties": {
        "Points": {
          "type": [
            "null",
            "array"
          ],
          "items": {
            "$ref": "#/$defs/WhatIfPoint"
          }
        }
      },
      "required": [
        "Points"
      ],
      "additionalProperties": false
    },
    "WhatIfPoint": {
      "type": "object",
      "properties": {
        "Replicas": {
          "type": "integer"
