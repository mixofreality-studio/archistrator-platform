      "required": [
        "OperatedAppID",
        "Phase",
        "InFlight",
        "Health",
        "Slos",
        "RecentEvents",
        "Autoscaler",
        "CurrentRunRate"
      ],
      "additionalProperties": false
    },
    "PatchKind": {
      "type": "integer",
      "enum": [
        0,
        1,
        2,
        3
      ],
      "x-enum-varnames": [
        "PatchKindUnknown",
        "PatchFullBundle",
        "PatchScale",
        "PatchPolicy"
      ],
      "x-go-base": "int"
    },
