        "Health": {
          "$ref": "#/$defs/HealthSnapshotView"
        },
        "Slos": {
          "type": [
            "null",
            "array"
          ],
          "items": {
            "$ref": "#/$defs/SloRowView"
          }
        },
        "RecentEvents": {
          "type": [
            "null",
            "array"
          ],
          "items": {
            "$ref": "#/$defs/RuntimeStatusEventView"
          }
        },
        "Autoscaler": {
          "$ref": "#/$defs/AutoscalerView"
        },
        "CurrentRunRate": {
          "$ref": "#/$defs/Money"
        }
