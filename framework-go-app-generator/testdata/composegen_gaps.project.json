{
 "id": "greenfield",
 "version": 1,
 "slots": {
  "5": {
   "status": 2,
   "kind": 5,
   "model": {
    "components": [
     {
      "id": "web-client",
      "name": "WebClient",
      "kind": "client",
      "layer": "client",
      "encapsulates": "Transport entry point for the browser SPA.",
      "atomicBusinessVerbs": []
     },
     {
      "id": "order-manager",
      "name": "OrderManager",
      "kind": "manager",
      "layer": "manager",
      "encapsulates": "Encapsulates the order lifecycle workflow: place, price, charge, cancel.",
      "atomicBusinessVerbs": []
     },
     {
      "id": "order-state-access",
      "name": "OrderStateAccess",
      "kind": "resourceAccess",
      "layer": "resourceAccess",
      "encapsulates": "Encapsulates the order-state store: read/put/cancel/charge over the order record.",
      "atomicBusinessVerbs": [
       "readOrder",
       "putOrder",
       "cancelOrder",
       "chargeOrder"
      ]
     },
     {
      "id": "pricing-engine",
      "name": "PricingEngine",
      "kind": "engine",
      "layer": "engine",
      "encapsulates": "Encapsulates the order pricing policy: order -> price quote.",
      "atomicBusinessVerbs": []
     },
     {
      "id": "fulfillment-manager",
      "name": "FulfillmentManager",
      "kind": "manager",
      "layer": "manager",
      "encapsulates": "Encapsulates the shipment fulfillment workflow: query carrier status, ping carrier liveness.",
      "atomicBusinessVerbs": []
     }
    ],
    "relationships": [
     {
      "from": "web-client",
      "to": "order-manager",
      "mode": "sync",
      "label": "placeOrder | cancelOrder"
     },
     {
      "from": "order-manager",
      "to": "order-state-access",
      "mode": "sync",
      "label": "readOrder | putOrder | cancelOrder | chargeOrder"
     },
     {
      "from": "order-manager",
      "to": "pricing-engine",
      "mode": "sync",
      "label": "price"
     },
     {
      "from": "web-client",
      "to": "fulfillment-manager",
      "mode": "sync",
      "label": "getShipmentStatus | pingCarrier"
     }
    ],
    "dynamicViews": []
   }
  },
  "6": {
   "kind": 6,
   "model": {
    "deployment": {
     "deliveryStyle": "cloud",
     "containers": [
      {
       "key": "order-app",
       "name": "order-app",
       "components": [
        "orderManager",
        "orderStateAccess"
       ]
      }
     ],
     "environments": [
      {
       "profile": "cloud",
       "title": "Cloud"
      },
      {
       "profile": "local",
       "title": "Local"
      }
     ],
     "infrastructure": [
      {
       "key": "otel",
       "substrate": "otel",
       "profiles": [
        "cloud",
        "local"
       ],
       "presence": "optional"
      },
      {
       "key": "temporal",
       "substrate": "temporal",
       "profiles": [
        "cloud",
        "local"
       ],
       "presence": "required",
       "env": {
        "HOSTPORT": "ORDER_TEMPORAL_ADDR"
       }
      },
      {
       "key": "postgres",
       "substrate": "postgres",
       "profiles": [
        "cloud"
       ],
       "presence": "required"
      },
      {
       "key": "github-app",
       "substrate": "github-app",
       "profiles": [
        "cloud"
       ],
       "presence": "optional-dormant"
      },
      {
       "key": "keycloak",
       "substrate": "keycloak",
       "profiles": [
        "cloud"
       ],
       "presence": "optional"
      }
     ],
     "bindings": [
      {
       "component": "orderStateAccess",
       "presence": "optional-dormant",
       "perProfile": {
        "cloud": {
         "variant": "postgres",
         "infra": [
          "postgres"
         ]
        },
        "local": {
         "variant": "memory",
         "infra": []
        }
       }
      },
      {
       "component": "ledgerStateAccess",
       "presence": "required",
       "provides": [],
       "settings": [],
       "perProfile": {}
      }
     ],
     "settings": [
      {
       "name": "listenAddr",
       "type": "string",
       "default": ":8080"
      },
      {
       "name": "authDevMode",
       "type": "bool",
       "default": "false"
      },
      {
       "name": "maxRetries",
       "type": "int",
       "default": "3"
      },
      {
       "name": "shutdownTimeout",
       "type": "duration",
       "default": "20s"
      }
     ]
    }
   }
  }
