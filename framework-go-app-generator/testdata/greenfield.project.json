            "kind": "engine",
            "layer": "engine",
            "encapsulates": "Encapsulates the order pricing policy: order -> price quote.",
            "atomicBusinessVerbs": []
          }
        ],
        "relationships": [
          {
            "from": "web-client",
            "to": "order-manager",
            "mode": "sync",
            "label": "placeOrder | cancelOrder"
          },
          {
            "from": "order-manager",
            "to": "order-state-access",
            "mode": "sync",
            "label": "readOrder | putOrder | cancelOrder | chargeOrder"
          },
          {
            "from": "order-manager",
            "to": "pricing-engine",
            "mode": "sync",
            "label": "price"
          }
        ],
        "dynamicViews": []
      }
    }
